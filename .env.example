# Postgres / pgvector
# These three are used by docker-compose.yml to configure the Postgres
# container. Change them from the defaults if running anywhere other than
# a local machine. DATABASE_URL below is for running the app WITHOUT
# Docker (pointing at your own local/remote Postgres instance) -- it
# should match POSTGRES_USER/PASSWORD/DB if you're also using Docker.
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb
DATABASE_URL=postgresql://raguser:ragpass@localhost:5432/ragdb

# Embedding model (local, sentence-transformers)
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-base
EMBEDDING_DIM=768

# LLM (Groq) - get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Retrieval
TOP_K=5

# Optional: Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
